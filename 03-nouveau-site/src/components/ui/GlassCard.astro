---
interface Props {
  class?: string;
  hover?: boolean;
}

const { class: className, hover = true } = Astro.props;
---

<div
  class:list={[
    'glass p-8',
    hover && 'will-change-transform hover:-translate-y-2 hover:shadow-glass-hover hover:border-primary/30 hover:bg-white/[0.09]',
    className,
  ]}
>
  <slot />
</div>
