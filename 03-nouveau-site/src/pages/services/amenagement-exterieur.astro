---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Container from '../../components/ui/Container.astro';
import GlassCard from '../../components/ui/GlassCard.astro';
import Button from '../../components/ui/Button.astro';
import Animate from '../../components/react/ScrollAnimations';
import Gallery from '../../components/ui/Gallery.astro';

const gallery = [
  { src: '/images/amenagement-01.jpg', alt: 'Pose de bordures bois et réalisation d\'un béton désactivé', caption: 'Pose de bordures bois et réalisation d\'un béton désactivé' },
  { src: '/images/amenagement-02.jpg', alt: 'Réalisation d\'une allée en béton balayé autour d\'une maison', caption: 'Réalisation d\'une allée en béton balayé autour d\'une maison' },
  { src: '/images/amenagement-03.jpg', alt: 'Réalisation d\'une allée en béton balayé et enrobés à chaud', caption: 'Réalisation d\'une allée en béton balayé et enrobés à chaud' },
  { src: '/images/amenagement-04.jpg', alt: 'Réalisation d\'un escalier en poutre bois et cailloux blanc', caption: 'Réalisation d\'un escalier en poutre bois + cailloux blanc' },
  { src: '/images/amenagement-05.jpg', alt: 'Réalisation d\'un escalier en poutres bois et bordures ardoise', caption: 'Réalisation d\'un escalier en poutres bois + bordures ardoise' }
];

const page = {
  title: 'Aménagement extérieur',
  description: 'Puechoultres & Fils réalise vos aménagements extérieurs en Aveyron : terrassement, clôtures, branchements EP/EU, béton balayé, désactivé et coloré, bordures et dallage.',
  hero: '/images/hero-amenagement.jpg',
};

const prestations = [
  'Terrassement et nivellement de terrain',
  'Pose de clôtures et portails',
  'Branchements eaux pluviales et eaux usées',
  'Béton balayé, désactivé et coloré',
  'Pose de bordures et caniveaux',
  'Dallage et pavage extérieur',
  'Création d\'allées et cours',
  'Aménagement de parkings privatifs',
  'Empierrement et stabilisation de chemins',
  'Création de fossés et drainage',
];

const autresServices = [
  { label: 'Goudronnage',        href: '/services/goudronnage' },
  { label: 'Voirie et réseaux',  href: '/services/voirie-et-reseaux' },
  { label: 'Assainissement',     href: '/services/assainissement' },
  { label: 'Béton prêt à l\'emploi', href: '/services/beton-pret-a-l-emploi' },
  { label: 'Travaux publics',    href: '/services/travaux-publics' },
  { label: 'Démolition',         href: '/services/demolition' },
];
---

<BaseLayout title={page.title} description={page.description}>
  <Header />
  <main>

    <section class="relative h-72 sm:h-96 flex items-end overflow-hidden">
      <img src={page.hero} alt="Aménagement extérieur Puech Oultres" class="absolute inset-0 w-full h-full object-cover object-center" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-black/20" />
      <Container class="relative z-10 pb-8 sm:pb-12">
        <nav aria-label="Fil d'Ariane" class="mb-3">
          <ol class="flex items-center gap-2 text-sm text-gray-400">
            <li><a href="/" class="hover:text-white transition-colors">Accueil</a></li>
            <li aria-hidden="true" class="text-gray-600">/</li>
            <li><a href="/services" class="hover:text-white transition-colors">Services</a></li>
            <li aria-hidden="true" class="text-gray-600">/</li>
            <li class="text-white font-medium" aria-current="page">Aménagement extérieur</li>
          </ol>
        </nav>
        <h1 class="font-heading font-black text-3xl sm:text-5xl text-white leading-tight">Aménagement extérieur</h1>
      </Container>
    </section>

    <section class="py-16 bg-gray-900">
      <Container>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">

          <div class="lg:col-span-8 flex flex-col gap-12">
            <Animate animation="slideUp" client:visible>
              <div>
                <h2 class="font-heading font-bold text-2xl sm:text-3xl text-white mb-5">Notre expertise</h2>
                <div class="space-y-4 text-gray-300 leading-relaxed">
                  <p>La SARL Puechoultres & Fils intervient pour tous vos projets d'aménagement extérieur, aussi bien pour les particuliers que pour les collectivités et les entreprises sur l'ensemble de l'Aveyron.</p>
                  <p>Du terrassement initial à la finition décorative, nos équipes maîtrisent l'ensemble des techniques de mise en œuvre : <strong class="text-white">béton balayé, désactivé et coloré</strong>, dallage, pose de bordures et branchements réseaux.</p>
                  <p>Chaque projet est étudié sur mesure pour s'adapter à la topographie du terrain, aux contraintes techniques et aux souhaits esthétiques de nos clients.</p>
                </div>
              </div>
            </Animate>

            <Animate animation="slideUp" delay={0.05} client:visible>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                {[
                  { title: 'Béton balayé', desc: 'Finition striée anti-dérapante, idéale pour allées et terrasses exposées aux intempéries.' },
                  { title: 'Béton désactivé', desc: 'Granulats apparents pour un aspect naturel et décoratif, résistant aux UV et au gel.' },
                  { title: 'Béton coloré', desc: 'Pigments dans la masse pour une intégration harmonieuse dans l\'environnement paysager.' },
                ].map(c => (
                  <div class="p-5 rounded-card border border-white/10 bg-white/5">
                    <h3 class="font-heading font-semibold text-white mb-2">{c.title}</h3>
                    <p class="text-gray-400 text-sm leading-relaxed">{c.desc}</p>
                  </div>
                ))}
              </div>
            </Animate>

            <Animate animation="slideUp" delay={0.1} client:visible>
              <div>
                <h2 class="font-heading font-bold text-2xl sm:text-3xl text-white mb-6">Nos prestations</h2>
                <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                  {prestations.map(item => (
                    <li class="flex items-start gap-3 text-gray-300">
                      <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12" /></svg>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </Animate>

            <Animate animation="slideUp" delay={0.15} client:visible>
              <div class="p-6 rounded-card border border-white/10 bg-white/5">
                <h3 class="font-heading font-semibold text-lg text-white mb-2">Particuliers et professionnels</h3>
                <p class="text-gray-400 text-sm leading-relaxed">Nous réalisons des aménagements de toutes envergures : de la simple allée privée aux grands parkings de collectivités. Déplacement gratuit pour étude et chiffrage sur place en Aveyron.</p>
              </div>
            </Animate>
          </div>

          <aside class="lg:col-span-4">
            <div class="lg:sticky lg:top-24 flex flex-col gap-6">
              <GlassCard hover={false}>
                <h3 class="font-heading font-bold text-lg text-white mb-5">Besoin d'un devis ?</h3>
                <form name="devis-amenagement" method="POST" data-netlify="true" class="flex flex-col gap-4">
                  <input type="hidden" name="form-name" value="devis-amenagement" />
                  <input type="hidden" name="service" value="Aménagement extérieur" />
                  <div>
                    <label for="nom" class="block text-xs font-medium text-gray-400 mb-1.5">Nom *</label>
                    <input id="nom" name="nom" type="text" required placeholder="Votre nom" class="w-full rounded-btn bg-white/5 border border-white/10 px-3 py-2.5 text-sm text-white placeholder:text-gray-500 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-colors" />
                  </div>
                  <div>
                    <label for="email" class="block text-xs font-medium text-gray-400 mb-1.5">Email *</label>
                    <input id="email" name="email" type="email" required placeholder="votre@email.fr" class="w-full rounded-btn bg-white/5 border border-white/10 px-3 py-2.5 text-sm text-white placeholder:text-gray-500 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-colors" />
                  </div>
                  <div>
                    <label for="telephone" class="block text-xs font-medium text-gray-400 mb-1.5">Téléphone</label>
                    <input id="telephone" name="telephone" type="tel" placeholder="06 00 00 00 00" class="w-full rounded-btn bg-white/5 border border-white/10 px-3 py-2.5 text-sm text-white placeholder:text-gray-500 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-colors" />
                  </div>
                  <div>
                    <label for="message" class="block text-xs font-medium text-gray-400 mb-1.5">Message *</label>
                    <textarea id="message" name="message" required rows="4" placeholder="Type d'aménagement, surface, commune…" class="w-full rounded-btn bg-white/5 border border-white/10 px-3 py-2.5 text-sm text-white placeholder:text-gray-500 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-colors resize-none"></textarea>
                  </div>
                  <Button variant="primary" class="w-full justify-center">Envoyer ma demande</Button>
                </form>
              </GlassCard>
              <GlassCard hover={false}>
                <h3 class="font-heading font-semibold text-base text-white mb-4">Autres services</h3>
                <ul class="flex flex-col gap-1">
                  {autresServices.map(s => (
                    <li>
                      <a href={s.href} class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-gray-400 hover:text-white hover:bg-white/10 transition-colors duration-[150ms]">
                        <svg class="w-3.5 h-3.5 text-primary shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
                        {s.label}
                      </a>
                    </li>
                  ))}
                </ul>
                <div class="mt-4 pt-4 border-t border-white/10">
                  <a href="/services" class="text-sm text-primary hover:text-primary-light font-medium transition-colors">Voir tous les services →</a>
                </div>
              </GlassCard>
            </div>
          </aside>

        </div>
      </Container>
    </section>

    <Gallery images={gallery} title="Nos réalisations aménagement extérieur" />

    <section class="relative py-20 overflow-hidden" style="background: linear-gradient(135deg, #1F1F1F 0%, #3B0A0A 50%, #1F1F1F 100%);">
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary to-transparent" aria-hidden="true" />
      <Container class="relative z-10 text-center">
        <Animate animation="slideUp" client:visible>
          <h2 class="font-heading font-black text-2xl sm:text-4xl text-white mb-4">Un projet d'aménagement ?</h2>
          <p class="text-gray-300 text-lg max-w-xl mx-auto mb-8">Déplacement gratuit pour étude et devis sur l'Aveyron.</p>
          <div class="flex flex-wrap justify-center gap-4">
            <Button href="/nous-contacter" variant="primary" size="lg">Contactez-nous</Button>
            <Button href="tel:0565690270" variant="outline" size="lg">05 65 69 02 70</Button>
          </div>
        </Animate>
      </Container>
    </section>

  </main>
  <Footer />
</BaseLayout>
