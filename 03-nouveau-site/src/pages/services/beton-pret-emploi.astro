---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Container from '../../components/ui/Container.astro';
import GlassCard from '../../components/ui/GlassCard.astro';
import Button from '../../components/ui/Button.astro';
import Animate from '../../components/react/ScrollAnimations';
import Gallery from '../../components/ui/Gallery.astro';

const gallery = [
  { src: '/images/beton-01.jpg', alt: 'Malaxeur 8X4 et pompe à béton 24 mètres', caption: 'Malaxeur 8X4 et Pompe à béton 24 mètres' },
  { src: '/images/beton-02.jpg', alt: 'Pompe à béton', caption: 'Pompe à béton' },
  { src: '/images/beton-03.jpg', alt: 'Malaxeur-Pompe', caption: 'Malaxeur-Pompe' }
];

const page = {
  title: 'Béton prêt à l\'emploi',
  description: 'Puechoultres & Fils dispose d\'une centrale à béton de 50 m³/h à Baraqueville et d\'une flotte de malaxeurs pour la livraison sur chantier en Aveyron.',
  hero: '/images/hero-beton.jpg',
};

const prestations = [
  'Centrale à béton — 50 m³/heure',
  '2 camions malaxeurs 6x4 (6 m³)',
  '2 camions malaxeurs 8x4 (8 m³)',
  'Malaxeur-pompe avec flèche de 24 ml',
  'Béton de fondation',
  'Béton de structure',
  'Béton désactivé et décoratif',
  'Livraison sur chantier, Aveyron et alentours',
];

const autresServices = [
  { label: 'Travaux publics',    href: '/services/travaux-publics' },
  { label: 'Transport',          href: '/services/transport' },
  { label: 'Voirie et réseaux',  href: '/services/voirie-et-reseaux' },
  { label: 'Assainissement',     href: '/services/assainissement' },
  { label: 'Goudronnage',        href: '/services/goudronnage' },
  { label: 'Démolition',         href: '/services/demolition' },
];
---

<BaseLayout title={page.title} description={page.description}>
  <Header />
  <main>

    <section class="relative h-72 sm:h-96 flex items-end overflow-hidden">
      <img src={page.hero} alt="Centrale à béton Puech Oultres à Baraqueville" class="absolute inset-0 w-full h-full object-cover object-center" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-black/20" />
      <Container class="relative z-10 pb-8 sm:pb-12">
        <nav aria-label="Fil d'Ariane" class="mb-3">
          <ol class="flex items-center gap-2 text-sm text-gray-400">
            <li><a href="/" class="hover:text-white transition-colors">Accueil</a></li>
            <li aria-hidden="true" class="text-gray-600">/</li>
            <li><a href="/services" class="hover:text-white transition-colors">Services</a></li>
            <li aria-hidden="true" class="text-gray-600">/</li>
            <li class="text-white font-medium" aria-current="page">Béton prêt à l'emploi</li>
          </ol>
        </nav>
        <h1 class="font-heading font-black text-3xl sm:text-5xl text-white leading-tight">Béton prêt à l'emploi</h1>
      </Container>
    </section>

    <section class="py-16 bg-gray-900">
      <Container>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">

          <div class="lg:col-span-8 flex flex-col gap-12">
            <Animate animation="slideUp" client:visible>
              <div>
                <h2 class="font-heading font-bold text-2xl sm:text-3xl text-white mb-5">Notre expertise</h2>
                <div class="space-y-4 text-gray-300 leading-relaxed">
                  <p>La SARL Puechoultres & Fils dispose d'une activité Béton Prêt à l'Emploi (BPE) et possède une centrale à béton implantée à Baraqueville, au cœur de l'Aveyron.</p>
                  <p>Avec une capacité de production de 50 m³ par heure et une flotte de malaxeurs adaptés, nous garantissons une livraison rapide et fiable sur tous vos chantiers. Notre malaxeur-pompe équipé d'une flèche de 24 mètres permet le coulage dans les zones difficiles d'accès.</p>
                  <p>Nous formulons des bétons adaptés à toutes les utilisations : fondations, structures, dalles, béton décoratif, selon les normes NF EN 206 en vigueur.</p>
                </div>
              </div>
            </Animate>

            <Animate animation="slideUp" delay={0.1} client:visible>
              <div>
                <h2 class="font-heading font-bold text-2xl sm:text-3xl text-white mb-6">Nos prestations</h2>
                <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                  {prestations.map(item => (
                    <li class="flex items-start gap-3 text-gray-300">
                      <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12" /></svg>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </Animate>

            <Animate animation="slideUp" delay={0.15} client:visible>
              <div class="p-6 rounded-card border border-white/10 bg-white/5">
                <h3 class="font-heading font-semibold text-lg text-white mb-2">Centrale à Baraqueville</h3>
                <p class="text-gray-400 text-sm leading-relaxed">Livraison sur l'Aveyron et les départements limitrophes. Commandes au <a href="tel:0565690270" class="text-primary hover:underline">05 65 69 02 70</a>.</p>
              </div>
            </Animate>
          </div>

          <aside class="lg:col-span-4">
            <div class="lg:sticky lg:top-24 flex flex-col gap-6">
              <GlassCard hover={false}>
                <h3 class="font-heading font-bold text-lg text-white mb-5">Besoin d'un devis ?</h3>
                <form name="devis-beton" method="POST" data-netlify="true" class="flex flex-col gap-4">
                  <input type="hidden" name="form-name" value="devis-beton" />
                  <input type="hidden" name="service" value="Béton prêt à l'emploi" />
                  <div>
                    <label for="nom" class="block text-xs font-medium text-gray-400 mb-1.5">Nom *</label>
                    <input id="nom" name="nom" type="text" required placeholder="Votre nom" class="w-full rounded-btn bg-white/5 border border-white/10 px-3 py-2.5 text-sm text-white placeholder:text-gray-500 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-colors" />
                  </div>
                  <div>
                    <label for="email" class="block text-xs font-medium text-gray-400 mb-1.5">Email *</label>
                    <input id="email" name="email" type="email" required placeholder="votre@email.fr" class="w-full rounded-btn bg-white/5 border border-white/10 px-3 py-2.5 text-sm text-white placeholder:text-gray-500 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-colors" />
                  </div>
                  <div>
                    <label for="telephone" class="block text-xs font-medium text-gray-400 mb-1.5">Téléphone</label>
                    <input id="telephone" name="telephone" type="tel" placeholder="06 00 00 00 00" class="w-full rounded-btn bg-white/5 border border-white/10 px-3 py-2.5 text-sm text-white placeholder:text-gray-500 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-colors" />
                  </div>
                  <div>
                    <label for="message" class="block text-xs font-medium text-gray-400 mb-1.5">Message *</label>
                    <textarea id="message" name="message" required rows="4" placeholder="Volume souhaité, type de béton, date…" class="w-full rounded-btn bg-white/5 border border-white/10 px-3 py-2.5 text-sm text-white placeholder:text-gray-500 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-colors resize-none"></textarea>
                  </div>
                  <Button variant="primary" class="w-full justify-center">Envoyer ma demande</Button>
                </form>
              </GlassCard>
              <GlassCard hover={false}>
                <h3 class="font-heading font-semibold text-base text-white mb-4">Autres services</h3>
                <ul class="flex flex-col gap-1">
                  {autresServices.map(s => (
                    <li>
                      <a href={s.href} class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-gray-400 hover:text-white hover:bg-white/10 transition-colors duration-[150ms] group">
                        <svg class="w-3.5 h-3.5 text-primary shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
                        {s.label}
                      </a>
                    </li>
                  ))}
                </ul>
                <div class="mt-4 pt-4 border-t border-white/10">
                  <a href="/services" class="text-sm text-primary hover:text-primary-light font-medium transition-colors">Voir tous les services →</a>
                </div>
              </GlassCard>
            </div>
          </aside>

        </div>
      </Container>
    </section>

    <Gallery images={gallery} title="Notre centrale à béton" />

    <section class="relative py-20 overflow-hidden" style="background: linear-gradient(135deg, #1F1F1F 0%, #3B0A0A 50%, #1F1F1F 100%);">
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary to-transparent" aria-hidden="true" />
      <Container class="relative z-10 text-center">
        <Animate animation="slideUp" client:visible>
          <h2 class="font-heading font-black text-2xl sm:text-4xl text-white mb-4">Un projet nécessitant du béton ?</h2>
          <p class="text-gray-300 text-lg max-w-xl mx-auto mb-8">Contactez-nous pour un devis de fourniture et pompage sur mesure.</p>
          <div class="flex flex-wrap justify-center gap-4">
            <Button href="/nous-contacter" variant="primary" size="lg">Contactez-nous</Button>
            <Button href="tel:0565690270" variant="outline" size="lg">05 65 69 02 70</Button>
          </div>
        </Animate>
      </Container>
    </section>

  </main>
  <Footer />
</BaseLayout>
