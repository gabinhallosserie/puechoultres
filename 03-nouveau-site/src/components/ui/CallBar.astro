---
/**
 * CallBar.astro
 * Bandeau d'appel fixe en bas d'écran — mobile uniquement (caché sur lg+).
 * Deux actions : appel direct + devis rapide.
 */
---

<div
  id="call-bar"
  class="fixed bottom-0 left-0 right-0 z-50 lg:hidden"
  role="navigation"
  aria-label="Actions rapides"
>
  <!-- Trait de séparation haut -->
  <div class="h-px bg-gradient-to-r from-transparent via-primary/60 to-transparent" aria-hidden="true" />

  <div class="flex items-stretch bg-gray-950/95 backdrop-blur-sm">

    <!-- Appel -->
    <a
      href="tel:0565690270"
      class="flex flex-1 items-center justify-center gap-2.5 bg-primary hover:bg-primary-dark active:scale-[0.98] transition-all duration-150 py-4 px-4 text-white font-semibold text-sm"
      aria-label="Appeler le 05 65 69 02 70"
    >
      <!-- Icône téléphone -->
      <svg class="w-4.5 h-4.5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6.08 6.08l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      <span>05 65 69 02 70</span>
    </a>

    <!-- Séparateur -->
    <div class="w-px bg-white/10 shrink-0" aria-hidden="true" />

    <!-- Devis -->
    <a
      href="/nous-contacter"
      class="flex flex-col items-center justify-center gap-0.5 px-5 text-gray-300 hover:text-white hover:bg-white/5 active:bg-white/10 transition-colors duration-150 text-xs font-medium"
      aria-label="Demander un devis"
    >
      <!-- Icône document -->
      <svg class="w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
      </svg>
      <span>Devis</span>
    </a>

  </div>

  <!-- Safe area iOS (encoche bas) -->
  <div class="h-safe-bottom bg-gray-950/95" style="height: env(safe-area-inset-bottom, 0px);" />
</div>
