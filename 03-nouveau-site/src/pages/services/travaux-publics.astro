---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Container from '../../components/ui/Container.astro';
import GlassCard from '../../components/ui/GlassCard.astro';
import Button from '../../components/ui/Button.astro';
import Animate from '../../components/react/ScrollAnimations';
import Gallery from '../../components/ui/Gallery.astro';

const gallery = [
  { src: '/images/travaux-publics-01.jpg', alt: 'Terrassement d\'un bâtiment agricole', caption: 'Terrassement d\'un bâtiment agricole' },
  { src: '/images/travaux-publics-02.jpg', alt: 'Terrassement d\'un bâtiment agricole', caption: 'Terrassement d\'un bâtiment agricole' },
  { src: '/images/travaux-publics-03.jpg', alt: 'Terrassement — chantier Aveyron', caption: 'Terrassement d\'un bâtiment agricole' },
  { src: '/images/travaux-publics-04.jpg', alt: 'Réalisation d\'un talus', caption: 'Réalisation d\'un talus' }
];

// ---- Données de la page (extraites du site original) ----
const page = {
  title: 'Travaux publics',
  description: 'Depuis plus de 40 ans, Puechoultres & Fils est spécialisée dans les travaux publics en Aveyron : terrassements, VRD, assainissement, démolition et aménagements.',
  hero: '/images/hero-travaux-publics.jpg',
};

const prestations = [
  'Terrassements',
  'VRD — Voirie et Réseaux Divers',
  'Désamiantage',
  'Assainissements collectifs et individuels',
  'Aménagement de cours d\'eau et rivières',
  'Fondations en puits (tarière Ø60 à Ø120)',
  'Aménagement de pavillons',
  'Goudronnage',
  'Démolitions',
  'Fosses à lisier et bassins en géo-membrane',
  'Location d\'engins et de matériels',
];

const autresServices = [
  { label: 'Transport',             href: '/services/transport' },
  { label: 'Béton prêt à l\'emploi', href: '/services/beton-pret-emploi' },
  { label: 'Désamiantage',          href: '/services/desamiantage' },
  { label: 'Goudronnage',           href: '/services/goudronnage' },
  { label: 'Démolition',            href: '/services/demolition' },
  { label: 'Assainissement',        href: '/services/assainissement' },
];
---

<BaseLayout title={page.title} description={page.description}>
  <Header />

  <main>

    <!-- ================================ -->
    <!--  HERO PAGE                       -->
    <!-- ================================ -->
    <section class="relative h-72 sm:h-96 flex items-end overflow-hidden">

      <!-- Image de fond -->
      <img
        src={page.hero}
        alt="Chantier de travaux publics Puech Oultres"
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="eager"
      />
      <!-- Overlay -->
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-black/20" />

      <Container class="relative z-10 pb-8 sm:pb-12">

        <!-- Breadcrumb -->
        <nav aria-label="Fil d'Ariane" class="mb-3">
          <ol class="flex items-center gap-2 text-sm text-gray-400">
            <li><a href="/" class="hover:text-white transition-colors">Accueil</a></li>
            <li aria-hidden="true" class="text-gray-600">/</li>
            <li><a href="/services" class="hover:text-white transition-colors">Services</a></li>
            <li aria-hidden="true" class="text-gray-600">/</li>
            <li class="text-white font-medium" aria-current="page">Travaux publics</li>
          </ol>
        </nav>

        <h1 class="font-heading font-black text-3xl sm:text-5xl text-white leading-tight">
          Travaux publics
        </h1>

      </Container>
    </section>


    <!-- ================================ -->
    <!--  CONTENU PRINCIPAL               -->
    <!-- ================================ -->
    <section class="py-16 bg-gray-900">
      <Container>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">

          <!-- ===== COLONNE GAUCHE 8/12 ===== -->
          <div class="lg:col-span-8 flex flex-col gap-12">

            <!-- Notre expertise -->
            <Animate animation="slideUp" client:visible>
              <div>
                <h2 class="font-heading font-bold text-2xl sm:text-3xl text-white mb-5">
                  Notre expertise
                </h2>
                <div class="space-y-4 text-gray-300 leading-relaxed">
                  <p>
                    Depuis plus de 40 ans, la SARL Puechoultres &amp; Fils est spécialisée dans
                    le domaine des travaux publics. Implantée à Baraqueville en Aveyron, notre
                    zone d'action couvre l'ensemble du département et les régions limitrophes.
                  </p>
                  <p>
                    Nous collaborons avec de grandes firmes multinationales telles que Bouygues,
                    Colas, EDF-GDF, Eiffage, Eurovia et SNCF, ainsi qu'avec les collectivités
                    locales et les artisans PME. Chaque chantier bénéficie de l'expérience de
                    nos équipes et d'un parc matériel complet constamment renouvelé.
                  </p>
                  <p>
                    La satisfaction de nos clients, la santé et la sécurité des personnes,
                    ainsi que la préservation de l'environnement font partie intégrante de
                    notre démarche de progrès.
                  </p>
                </div>
              </div>
            </Animate>

            <!-- Nos prestations -->
            <Animate animation="slideUp" delay={0.1} client:visible>
              <div>
                <h2 class="font-heading font-bold text-2xl sm:text-3xl text-white mb-6">
                  Nos prestations
                </h2>
                <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                  {prestations.map(item => (
                    <li class="flex items-start gap-3 text-gray-300">
                      <!-- Check icon -->
                      <svg
                        class="w-5 h-5 text-primary shrink-0 mt-0.5"
                        xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                        fill="none" stroke="currentColor"
                        stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <polyline points="20 6 9 17 4 12" />
                      </svg>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </Animate>

            <!-- Zone d'intervention -->
            <Animate animation="slideUp" delay={0.15} client:visible>
              <div class="p-6 rounded-card border border-white/10 bg-white/5">
                <h3 class="font-heading font-semibold text-lg text-white mb-2">
                  Zone d'intervention
                </h3>
                <p class="text-gray-400 text-sm leading-relaxed">
                  Département de l'Aveyron (12) et départements limitrophes.
                  Devis gratuit sur site, réponse sous 48h.
                </p>
              </div>
            </Animate>

          </div>

          <!-- ===== COLONNE DROITE 4/12 (sidebar) ===== -->
          <aside class="lg:col-span-4">
            <div class="lg:sticky lg:top-24 flex flex-col gap-6">

              <!-- Card devis -->
              <GlassCard hover={false}>
                <h3 class="font-heading font-bold text-lg text-white mb-5">
                  Besoin d'un devis ?
                </h3>

                <form
                  name="devis-travaux-publics"
                  method="POST"
                  data-netlify="true"
                  class="flex flex-col gap-4"
                >
                  <input type="hidden" name="form-name" value="devis-travaux-publics" />
                  <input type="hidden" name="service" value="Travaux publics" />

                  <div>
                    <label for="nom" class="block text-xs font-medium text-gray-400 mb-1.5">
                      Nom *
                    </label>
                    <input
                      id="nom" name="nom" type="text" required
                      placeholder="Votre nom"
                      class="w-full rounded-btn bg-white/5 border border-white/10 px-3 py-2.5 text-sm text-white placeholder:text-gray-500 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-colors"
                    />
                  </div>

                  <div>
                    <label for="email" class="block text-xs font-medium text-gray-400 mb-1.5">
                      Email *
                    </label>
                    <input
                      id="email" name="email" type="email" required
                      placeholder="votre@email.fr"
                      class="w-full rounded-btn bg-white/5 border border-white/10 px-3 py-2.5 text-sm text-white placeholder:text-gray-500 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-colors"
                    />
                  </div>

                  <div>
                    <label for="telephone" class="block text-xs font-medium text-gray-400 mb-1.5">
                      Téléphone
                    </label>
                    <input
                      id="telephone" name="telephone" type="tel"
                      placeholder="06 00 00 00 00"
                      class="w-full rounded-btn bg-white/5 border border-white/10 px-3 py-2.5 text-sm text-white placeholder:text-gray-500 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-colors"
                    />
                  </div>

                  <div>
                    <label for="message" class="block text-xs font-medium text-gray-400 mb-1.5">
                      Message *
                    </label>
                    <textarea
                      id="message" name="message" required rows="4"
                      placeholder="Décrivez votre projet…"
                      class="w-full rounded-btn bg-white/5 border border-white/10 px-3 py-2.5 text-sm text-white placeholder:text-gray-500 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-colors resize-none"
                    ></textarea>
                  </div>

                  <Button variant="primary" class="w-full justify-center">
                    Envoyer ma demande
                  </Button>
                </form>
              </GlassCard>

              <!-- Card autres services -->
              <GlassCard hover={false}>
                <h3 class="font-heading font-semibold text-base text-white mb-4">
                  Autres services
                </h3>
                <ul class="flex flex-col gap-1">
                  {autresServices.map(s => (
                    <li>
                      <a
                        href={s.href}
                        class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-gray-400 hover:text-white hover:bg-white/10 transition-colors duration-[150ms] group"
                      >
                        <svg
                          class="w-3.5 h-3.5 text-primary shrink-0 transition-transform duration-[150ms] group-hover:translate-x-0.5"
                          xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                          fill="none" stroke="currentColor"
                          stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                          aria-hidden="true"
                        >
                          <path d="M9 18l6-6-6-6"/>
                        </svg>
                        {s.label}
                      </a>
                    </li>
                  ))}
                </ul>

                <div class="mt-4 pt-4 border-t border-white/10">
                  <a
                    href="/services"
                    class="text-sm text-primary hover:text-primary-light font-medium transition-colors"
                  >
                    Voir tous les services →
                  </a>
                </div>
              </GlassCard>

            </div>
          </aside>

        </div>
      </Container>
    </section>


    <Gallery images={gallery} title="Nos chantiers travaux publics" />

    <!-- ================================ -->
    <!--  CTA BAS DE PAGE                 -->
    <!-- ================================ -->
    <section
      class="relative py-20 overflow-hidden"
      style="background: linear-gradient(135deg, #1F1F1F 0%, #3B0A0A 50%, #1F1F1F 100%);"
    >
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary to-transparent" aria-hidden="true" />

      <Container class="relative z-10 text-center">
        <Animate animation="slideUp" client:visible>
          <h2 class="font-heading font-black text-2xl sm:text-4xl text-white mb-4">
            Un projet en travaux publics&nbsp;?
          </h2>
          <p class="text-gray-300 text-lg max-w-xl mx-auto mb-8">
            Contactez nos équipes pour une étude gratuite et un devis personnalisé
            sous 48h.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <Button href="/nous-contacter" variant="primary" size="lg">
              Contactez-nous
            </Button>
            <Button href="tel:0565690270" variant="outline" size="lg">
              05 65 69 02 70
            </Button>
          </div>
        </Animate>
      </Container>
    </section>

  </main>

  <Footer />
</BaseLayout>
